# ===========================================
# Notre Famille — Variables d'environnement
# ===========================================
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS commit .env.local sur GitHub !

# Mot de passe d'accès au site
SITE_PASSWORD=ton-mot-de-passe-ici

# Secret pour signer les cookies de session (générer une chaîne aléatoire longue)
SESSION_SECRET=generer-une-chaine-aleatoire-de-64-caracteres-minimum

# Firebase Admin SDK (depuis la console Firebase > Paramètres > Comptes de service)
FIREBASE_ADMIN_PROJECT_ID=notre-famille-xxxxx
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@notre-famille-xxxxx.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxxxxx\n-----END PRIVATE KEY-----\n"
